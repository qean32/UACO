generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Group {
  code     String @id @unique
  semester Int   @default(1)

  createdAt  DateTime @default(now())
  updateadAt DateTime @updatedAt

  Department     Department? @relation(fields: [DepartmentCode], references: [code], onDelete: Cascade)
  DepartmentCode String?

  students User[]
}

model Department {
  code String @id @unique
  name String @unique

  groups Group[]
}

model User {
  id Int @id @default(autoincrement())

  firstName   String
  lastName    String
  sureName    String
  dateOfBirth DateTime

  role Role @default(STUDENT)
  sex  Sex  @default(MALE)

  email    String
  password String

  Group     Group?  @relation(fields: [GroupCode], references: [code], onDelete: Cascade)
  GroupCode String?

  createdAt  DateTime @default(now())
  updateadAt DateTime @updatedAt

  organizedEvents   Event[]
  estimationsEvents EstimationEvent[]
}

model EstimationEvent {
  id         Int @id @default(autoincrement())
  estimation Int @default(0)

  User   User @relation(fields: [UserId], references: [id], onDelete: Cascade)
  UserId Int

  Event   Event @relation(fields: [EventId], references: [id], onDelete: Cascade)
  EventId Int

  createdAt  DateTime @default(now())
  updateadAt DateTime @updatedAt
}

model Event {
  id   Int    @id @default(autoincrement())
  name String

  date      DateTime
  createdAt DateTime @default(now())

  Supervisor   User? @relation(fields: [SupervisorId], references: [id], onDelete: Cascade)
  SupervisorId Int?

  estimationsEvents EstimationEvent[]
}

enum Role {
  STUDENT
  SUPERVISOR
  ADMIN
}

enum Sex {
  MALE
  FEMALE
}
